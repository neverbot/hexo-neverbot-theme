<meta charset="UTF-8">
<script>(function(){try{var t=localStorage.getItem('theme');if(t)document.documentElement.setAttribute('data-theme',t)}catch(e){}})()</script>
<meta name="viewport"
      content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="ie=edge">
<% if (config.author) { %><meta name="author" content="<%- config.author %>"><% } %>
<% if (config.subtitle) { %><meta name="subtitle" content="<%- config.subtitle %>"><% } %>
<%
var description = '';
if (is_post() || is_page()) {
  description = strip_html(page.excerpt || page.content || '').replace(/\\/g, '').replace(/\s+/g, ' ').substring(0, 200).trim();
}
if (!description && config.description) {
  description = config.description;
}
if (description) { %>
<meta name="description" content="<%- description.replace(/"/g, '&quot;') %>">
<% } %>
<% if (config.keywords) { %><meta name="keywords" content="<%- config.keywords %>"><% } %>
<%
var title = page.title;

if (is_archive()) {
  title = __('archive_a');

  if (is_month()) {
    title += ': ' + page.year + '/' + page.month;
  } else if (is_year()) {
    title += ': ' + page.year;
  }
} else if (is_tag()) {
  title = 'Etiquetado como: ' + page.tag;
}
%>
<title><%= config.title %><% if (title) { %> | <%= title %><% } %></title>

<%# favicons %>
<% if (theme.icons) { %>
<link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png">
<% } %>

<% if (is_archive()) { %>
<meta name="robots" content="noindex">
<% } %>
<%- autoCanonical(config, page) %>
<link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml">

<%# Open Graph %>
<%
var ogImage = '';
if (is_post() || is_page()) {
  var imgMatch = (page.content || '').match(/<img[^>]+src=["']([^"']+)["']/);
  if (imgMatch) {
    ogImage = imgMatch[1];
    if (ogImage.startsWith('http')) {
      // already absolute
    } else if (ogImage.startsWith('/')) {
      ogImage = config.url + ogImage;
    } else {
      // relative path — resolve against page permalink
      var basePath = url_for(page.path).replace(/[^/]*$/, '');
      ogImage = config.url + basePath + ogImage.replace(/^\.\//, '');
    }
  }
}
if (!ogImage) ogImage = config.url + '/icons/apple-touch-icon.png';
%>
<meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
<meta property="og:title" content="<%= title ? config.title + ' | ' + title : config.title %>">
<% if (description) { %>
<meta property="og:description" content="<%- description.replace(/"/g, '&quot;') %>">
<% } %>
<meta property="og:url" content="<%- page.permalink || config.url %>">
<meta property="og:site_name" content="<%= config.title %>">
<meta property="og:image" content="<%- ogImage %>">

<%# css list %>
<% if (theme.stylesheets !== undefined && theme.stylesheets.length > 0) { %>
<!-- stylesheets list from _config.yml -->
<% theme.stylesheets.forEach(url => { %>
<link rel="stylesheet" href="<%- url_for(url, { ignore: true }) %>">
<% }); %>
<% } %>

<%# javascript list %>
<% if (theme.scripts !== undefined && theme.scripts.length > 0) { %>
<!-- scripts list from _config.yml -->
<% theme.scripts.forEach(url => { %>
<script src="<%- url_for(url, { ignore: true }) %>"></script>
<% }); %>
<% } %>

<%# video %>
<%# if (is_post() && page.video) { %>
<script src="https://cdn.plyr.io/3.8.4/plyr.js"></script>
<link rel="stylesheet" href="https://cdn.plyr.io/3.8.4/plyr.css" />
<%# } %>

<%# home scripts (no jquery) %>
<% if (url_for(page.path) == '/index.html'){ %>
<script defer src="<%- url_for('/js/home.js', { ignore: true })%>"></script>
<script defer src="<%- url_for('/js/sidebar.js', { ignore: true })%>"></script>
<% } %>

<style>
  <%- fa_css() %>
</style>
